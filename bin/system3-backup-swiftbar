#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/system3-backup-env.sh"
system3_backup_load_env

STATUS_FILE="$SYSTEM3_BACKUP_STATUS_FILE"
DISPLAY_NAME="$SYSTEM3_BACKUP_DISPLAY_NAME"
BACKUP_COMMAND="${SYSTEM3_BACKUP_RUNTIME_ENTRYPOINT:-$SCRIPT_DIR/system3-backup-backup}"
VERIFY_COMMAND="${SYSTEM3_BACKUP_VERIFY_SCRIPT:-$SCRIPT_DIR/system3-backup-verify}"
DASHBOARD_COMMAND="${SYSTEM3_BACKUP_DASHBOARD_ENTRYPOINT:-$SCRIPT_DIR/system3-backup-dashboard}"
DASHBOARD_OUTPUT="${SYSTEM3_BACKUP_DASHBOARD_OUTPUT:-$SYSTEM3_BACKUP_DASHBOARD_DIR/index.html}"
STATUS_DATA_COMMAND="${SYSTEM3_BACKUP_STATUS_DATA_COMMAND:-$SCRIPT_DIR/system3-backup-status-data}"
SCHEDULER_SERVICE="${SYSTEM3_BACKUP_SCHEDULER_SERVICE:-}"
SCHEDULER_PLIST="${SYSTEM3_BACKUP_SCHEDULER_PLIST:-}"
HC_DETAILS_URL="${SYSTEM3_BACKUP_HEALTHCHECKS_CHECK_URL:-${HEALTHCHECKS_DETAILS_URL:-}}"
STORAGE_URL="${SYSTEM3_BACKUP_STORAGE_URL:-}"
BACKUP_PROCESS_MATCH="${SYSTEM3_BACKUP_BACKUP_PROCESS_MATCH:-restic backup}"
BACKUP_PID_FILE="$SYSTEM3_BACKUP_PID_FILE"
VERIFY_PID_FILE="$SYSTEM3_BACKUP_VERIFY_PID_FILE"
WARNING_TEXT_COLOR="#9A5B00"
CRITICAL_TEXT_COLOR="#C2342C"

pid_from_file() {
    local pid_file="$1"
    local pid=""

    [[ -f "$pid_file" ]] || return 1
    pid="$(cat "$pid_file" 2>/dev/null || true)"
    [[ -n "$pid" ]] || return 1
    if kill -0 "$pid" 2>/dev/null; then
        echo "$pid"
        return 0
    fi
    return 1
}

swiftbar_shell_command() {
    local command="$1"
    printf "'%s'" "$command"
}

section_label() {
    local label="$1"
    echo "${label} | size=11 color=#666"
}

MISSING_CREDENTIAL_VARS=()
while IFS= read -r missing_var; do
    [[ -z "$missing_var" ]] && continue
    MISSING_CREDENTIAL_VARS+=("$missing_var")
done < <(system3_backup_missing_runtime_credentials)
if (( ${#MISSING_CREDENTIAL_VARS[@]} > 0 )); then
    MISSING_TEXT="${MISSING_CREDENTIAL_VARS[*]}"
    MISSING_TEXT="${MISSING_TEXT// /, }"
    echo "🔴 No creds"
    echo "---"
    echo "Missing credentials: ${MISSING_TEXT} | color=red"
    exit 0
fi

CURRENT_STATE=""
if [[ -f "$STATUS_FILE" ]]; then
    CURRENT_STATE="$(
        python3 - "$STATUS_FILE" <<'PY'
import json
import sys

try:
    with open(sys.argv[1]) as f:
        data = json.load(f)
    print(data.get("state", ""))
except Exception:
    pass
PY
    )"
fi

SUMMARY_JSON="$("$STATUS_DATA_COMMAND" 2>/dev/null || true)"
if [[ -z "$SUMMARY_JSON" ]]; then
    SUMMARY_JSON="{}"
fi
SUMMARY_INFO="$(
    STATUS_SUMMARY_JSON="$SUMMARY_JSON" python3 - <<'PY'
import json
import os

try:
    data = json.loads(os.environ.get("STATUS_SUMMARY_JSON", "{}"))
except Exception:
    data = {}

for key in (
    "status_health",
    "status_code",
    "status_text",
    "status_detail",
    "verify_health",
    "verify_text",
    "verify_detail",
    "verify_check_age",
    "verify_restore_age",
    "verify_check_due_label",
    "verify_restore_due_label",
    "verify_check_due_detail",
    "verify_restore_due_detail",
    "latest_full_age",
    "latest_full_snapshot",
    "latest_full_present",
    "latest_full_age_hours",
    "latest_full_title",
    "next_run_detail",
    "next_run_label",
    "next_run_time",
):
    value = data.get(key, "")
    if isinstance(value, bool):
        print("yes" if value else "no")
    elif value is None:
        print("")
    else:
        print(value)
PY
)"
SUMMARY_STATUS_HEALTH="$(echo "$SUMMARY_INFO" | sed -n '1p')"
SUMMARY_STATUS_CODE="$(echo "$SUMMARY_INFO" | sed -n '2p')"
SUMMARY_STATUS_TEXT="$(echo "$SUMMARY_INFO" | sed -n '3p')"
SUMMARY_STATUS_DETAIL="$(echo "$SUMMARY_INFO" | sed -n '4p')"
SUMMARY_VERIFY_HEALTH="$(echo "$SUMMARY_INFO" | sed -n '5p')"
SUMMARY_VERIFY_TEXT="$(echo "$SUMMARY_INFO" | sed -n '6p')"
SUMMARY_VERIFY_DETAIL="$(echo "$SUMMARY_INFO" | sed -n '7p')"
SUMMARY_VERIFY_CHECK_AGE="$(echo "$SUMMARY_INFO" | sed -n '8p')"
SUMMARY_VERIFY_RESTORE_AGE="$(echo "$SUMMARY_INFO" | sed -n '9p')"
SUMMARY_VERIFY_CHECK_DUE_LABEL="$(echo "$SUMMARY_INFO" | sed -n '10p')"
SUMMARY_VERIFY_RESTORE_DUE_LABEL="$(echo "$SUMMARY_INFO" | sed -n '11p')"
SUMMARY_VERIFY_CHECK_DUE_DETAIL="$(echo "$SUMMARY_INFO" | sed -n '12p')"
SUMMARY_VERIFY_RESTORE_DUE_DETAIL="$(echo "$SUMMARY_INFO" | sed -n '13p')"
SUMMARY_LATEST_FULL_AGE="$(echo "$SUMMARY_INFO" | sed -n '14p')"
SUMMARY_LATEST_FULL_SNAPSHOT="$(echo "$SUMMARY_INFO" | sed -n '15p')"
SUMMARY_LATEST_FULL_PRESENT="$(echo "$SUMMARY_INFO" | sed -n '16p')"
SUMMARY_LATEST_FULL_HOURS="$(echo "$SUMMARY_INFO" | sed -n '17p')"
SUMMARY_LATEST_FULL_TITLE="$(echo "$SUMMARY_INFO" | sed -n '18p')"
SUMMARY_NEXT_RUN_DETAIL="$(echo "$SUMMARY_INFO" | sed -n '19p')"
SUMMARY_NEXT_RUN_LABEL="$(echo "$SUMMARY_INFO" | sed -n '20p')"
SUMMARY_NEXT_RUN_TIME="$(echo "$SUMMARY_INFO" | sed -n '21p')"

RESTIC_PID=""
RESTIC_PID="$(pid_from_file "$BACKUP_PID_FILE" || true)"
UPLOAD_STATE="none"
if [[ -n "$RESTIC_PID" ]]; then
    PROC_STAT="$(ps -p "$RESTIC_PID" -o stat= 2>/dev/null || true)"
    if [[ "$PROC_STAT" == *T* ]]; then
        UPLOAD_STATE="paused"
    else
        UPLOAD_STATE="running"
    fi
fi

VERIFY_PID="$(pid_from_file "$VERIFY_PID_FILE" || true)"
VERIFY_RUNNING="no"
if [[ -n "$VERIFY_PID" ]]; then
    VERIFY_RUNNING="yes"
fi

LAUNCHD_LOADED=1
if [[ -n "$SCHEDULER_SERVICE" ]]; then
    if launchctl list 2>/dev/null | grep -Fq "$SCHEDULER_SERVICE"; then
        LAUNCHD_LOADED=1
    else
        LAUNCHD_LOADED=0
    fi
fi

VERIFY_CHECK_AGE="${SUMMARY_VERIFY_CHECK_AGE:-never}"
VERIFY_RESTORE_AGE="${SUMMARY_VERIFY_RESTORE_AGE:-never}"
VERIFY_CHECK_LINE_SUFFIX=""
VERIFY_RESTORE_LINE_SUFFIX=""
BACKUP_LINE_SUFFIX=""
if [[ -n "${SUMMARY_VERIFY_CHECK_DUE_LABEL:-}" ]]; then
    VERIFY_CHECK_LINE_SUFFIX=" (next ${SUMMARY_VERIFY_CHECK_DUE_LABEL})"
fi
if [[ -n "${SUMMARY_VERIFY_RESTORE_DUE_LABEL:-}" ]]; then
    VERIFY_RESTORE_LINE_SUFFIX=" (next ${SUMMARY_VERIFY_RESTORE_DUE_LABEL})"
fi
if [[ -n "${SUMMARY_NEXT_RUN_LABEL:-}" ]]; then
    BACKUP_LINE_SUFFIX=" (next ${SUMMARY_NEXT_RUN_LABEL})"
elif [[ -n "${SUMMARY_NEXT_RUN_DETAIL:-}" ]]; then
    BACKUP_LINE_SUFFIX=" (next ${SUMMARY_NEXT_RUN_DETAIL})"
fi

title_gb_from_status() {
    python3 - "$STATUS_FILE" <<'PY'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

print(f"{int(data.get('gb_done', 0))}/{int(data.get('gb_total', 0))}GB")
PY
}

# title bar

if [[ "$UPLOAD_STATE" == "paused" && -f "$STATUS_FILE" ]]; then
    TITLE_GB="$(title_gb_from_status 2>/dev/null || true)"
    echo "${TITLE_GB:-paused} | sfimage=pause.circle.fill sfcolor=FF9500"
elif [[ "$UPLOAD_STATE" == "running" && -f "$STATUS_FILE" ]]; then
    TITLE_GB="$(title_gb_from_status 2>/dev/null || true)"
    echo "${TITLE_GB:-running} | sfimage=arrow.triangle.2.circlepath sfcolor=007AFF"
elif [[ "$UPLOAD_STATE" == "paused" ]]; then
    echo "paused | sfimage=pause.circle.fill sfcolor=FF9500"
elif [[ "$UPLOAD_STATE" == "running" ]]; then
    echo "running | sfimage=arrow.triangle.2.circlepath sfcolor=007AFF"
elif [[ "$SUMMARY_STATUS_CODE" == "verification_running" ]]; then
    echo "verify | sfimage=checkmark.shield.fill sfcolor=007AFF"
elif [[ "$LAUNCHD_LOADED" -eq 0 ]]; then
    echo "pause | sfimage=pause.circle.fill sfcolor=FF9500"
elif [[ "$SUMMARY_STATUS_CODE" == "maintenance_warning" ]]; then
    echo "warn | sfimage=exclamationmark.triangle.fill sfcolor=FF9500"
elif [[ "$SUMMARY_STATUS_CODE" == "waiting_for_network" ]]; then
    echo "net | sfimage=wifi.slash sfcolor=FF9500"
elif [[ "$SUMMARY_STATUS_CODE" == "retry_pending" ]]; then
    echo "retry | sfimage=arrow.clockwise sfcolor=FF9500"
elif [[ "$SUMMARY_STATUS_CODE" == "no_full_backup" ]]; then
    echo "none | sfimage=exclamationmark.circle.fill sfcolor=FF3B30"
else
    if [[ "$SUMMARY_STATUS_CODE" == "verification_failed" ]]; then
        echo "fail | sfimage=exclamationmark.circle.fill sfcolor=FF3B30"
    elif [[ "$SUMMARY_STATUS_HEALTH" == "ok" ]]; then
        echo "| sfimage=externaldrive.badge.checkmark sfcolor=34C759"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_proof_stale" || "$SUMMARY_STATUS_CODE" == "backup_delayed_proof_stale" ]]; then
        echo "proof | sfimage=exclamationmark.triangle.fill sfcolor=FF9500"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_delayed" ]]; then
        echo "late | sfimage=clock.fill sfcolor=FF9500"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_overdue" ]]; then
        echo "fix | sfimage=exclamationmark.circle.fill sfcolor=FF3B30"
    else
        echo "${SUMMARY_LATEST_FULL_TITLE:-old} | sfimage=exclamationmark.circle.fill sfcolor=FF3B30"
    fi
fi

echo "---"
echo "${DISPLAY_NAME} | size=14 color=#444 sfimage=externaldrive.badge.checkmark"
echo "---"

# section 1: status

if [[ "$UPLOAD_STATE" != "none" && -f "$STATUS_FILE" ]]; then
    STATUS_DATA="$(
        python3 - "$STATUS_FILE" <<'PY'
import json
import sys

with open(sys.argv[1]) as f:
    data = json.load(f)

pct = data.get("pct", 0)
gb_done = data.get("gb_done", 0)
gb_total = data.get("gb_total", 0)
files_done = data.get("files_done", 0)
total_files = data.get("total_files", 0)
elapsed = data.get("time", 0)
gb_remaining = gb_total - gb_done
filled = int(pct / 5)
bar = "█" * filled + "░" * (20 - filled)
if elapsed >= 3600:
    elapsed_str = f"{int(elapsed // 3600)}h {int((elapsed % 3600) // 60)}m"
elif elapsed >= 60:
    elapsed_str = f"{int(elapsed // 60)}m"
else:
    elapsed_str = f"{int(elapsed)}s"

print(f"{bar} {pct:.0f}%")
print(f"{gb_done:.1f} GB of {int(gb_total)} GB processed ({int(gb_remaining)} GB remaining)")
print(f"{files_done:,} of {total_files:,} files")
print(elapsed_str)
PY
    )"

    if [[ -n "$STATUS_DATA" ]]; then
        if [[ "$UPLOAD_STATE" == "paused" ]]; then
            if [[ "$SUMMARY_LATEST_FULL_PRESENT" != "yes" ]]; then
                echo "First backup paused | color=#FF9500 size=14"
            else
                echo "Backup paused | color=#FF9500 size=14"
            fi
        else
            if [[ "$SUMMARY_LATEST_FULL_PRESENT" != "yes" ]]; then
                echo "First backup running | color=#007AFF size=14"
            else
                echo "Backup running | color=#007AFF size=14"
            fi
        fi
        echo "  $(echo "$STATUS_DATA" | sed -n '1p') | font=Menlo size=12"
        echo "  $(echo "$STATUS_DATA" | sed -n '2p') | size=13"
        echo "  $(echo "$STATUS_DATA" | sed -n '3p') | size=13"
        echo "  Elapsed: $(echo "$STATUS_DATA" | sed -n '4p') | size=13 color=#888"
    else
        echo "Backup starting... | color=#007AFF size=14"
    fi
elif [[ "$UPLOAD_STATE" != "none" ]]; then
    echo "Backup starting... | color=#007AFF size=14"
elif [[ "$SUMMARY_STATUS_CODE" == "verification_running" ]]; then
    echo "Recovery proof running | color=#007AFF size=14"
    if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    echo "  ${SUMMARY_STATUS_DETAIL} | size=13"
elif [[ "$LAUNCHD_LOADED" -eq 0 ]]; then
    echo "Backups paused | color=#FF9500 size=14"
elif [[ "$SUMMARY_STATUS_CODE" == "maintenance_warning" ]]; then
    DETAIL="$(
        python3 - "$STATUS_FILE" <<'PY'
import json
import sys
from datetime import datetime

with open(sys.argv[1]) as f:
    data = json.load(f)

failures = data.get("failures", 0)
next_attempt = data.get("next_attempt", "")
if next_attempt:
    try:
        target = datetime.strptime(next_attempt, "%Y-%m-%dT%H:%M:%S")
        diff = target - datetime.now()
        mins = max(0, int(diff.total_seconds() / 60))
        if mins >= 60:
            when = f"{mins // 60}h {mins % 60}m"
        else:
            when = f"{mins}m"
        print(f"Next scheduled retry: ~{when}")
    except Exception:
        print("Next scheduled retry: scheduled")
else:
    print("Next scheduled retry: scheduled")
print(f"{failures} consecutive failure(s)")
PY
    )"
    echo "Snapshot completed, cleanup warning | color=${WARNING_TEXT_COLOR} size=14"
    if [[ "$SUMMARY_LATEST_FULL_PRESENT" == "yes" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    echo "  Retention cleanup failed after snapshot creation | size=13"
    echo "  $(echo "$DETAIL" | sed -n '1p') | size=13 color=#888"
    echo "  $(echo "$DETAIL" | sed -n '2p') | size=13 color=#888"
elif [[ "$SUMMARY_STATUS_CODE" == "waiting_for_network" ]]; then
    DETAIL="$(
        python3 - "$STATUS_FILE" <<'PY'
import json
import sys
from datetime import datetime

with open(sys.argv[1]) as f:
    data = json.load(f)

failures = data.get("failures", 0)
next_attempt = data.get("next_attempt", "")
if next_attempt:
    try:
        target = datetime.strptime(next_attempt, "%Y-%m-%dT%H:%M:%S")
        diff = target - datetime.now()
        mins = max(0, int(diff.total_seconds() / 60))
        if mins >= 60:
            when = f"{mins // 60}h {mins % 60}m"
        else:
            when = f"{mins}m"
    except Exception:
        when = ""
else:
    when = ""

if when:
    print(f"Retrying in ~{when}")
else:
    print("Retry scheduled")
print(f"{failures} consecutive failure(s)")
PY
    )"
    echo "Waiting for network | color=${WARNING_TEXT_COLOR} size=14"
    if [[ "$SUMMARY_LATEST_FULL_PRESENT" == "yes" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    echo "  $(echo "$DETAIL" | sed -n '1p') | size=13"
    echo "  $(echo "$DETAIL" | sed -n '2p') | size=13 color=#888"
elif [[ "$SUMMARY_STATUS_CODE" == "retry_pending" ]]; then
    DETAIL="$(
        python3 - "$STATUS_FILE" <<'PY'
import json
import sys
from datetime import datetime

with open(sys.argv[1]) as f:
    data = json.load(f)

failures = data.get("failures", 0)
last_pct = data.get("last_progress", "unknown")
next_attempt = data.get("next_attempt", "")
if next_attempt:
    try:
        target = datetime.strptime(next_attempt, "%Y-%m-%dT%H:%M:%S")
        diff = target - datetime.now()
        mins = max(0, int(diff.total_seconds() / 60))
        if mins >= 60:
            when = f"{mins // 60}h {mins % 60}m"
        else:
            when = f"{mins}m"
        print(f"Last attempt reached {last_pct} — retry in ~{when}")
    except Exception:
        print(f"Last attempt reached {last_pct} — retry scheduled")
else:
    print(f"Last attempt reached {last_pct} — retry scheduled")
print(f"{failures} consecutive failure(s)")
PY
    )"
    echo "Backup failed, will retry | color=${WARNING_TEXT_COLOR} size=14"
    if [[ "$SUMMARY_LATEST_FULL_PRESENT" == "yes" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    echo "  $(echo "$DETAIL" | sed -n '1p') | size=13"
    echo "  $(echo "$DETAIL" | sed -n '2p') | size=13 color=#888"
elif [[ "$SUMMARY_STATUS_CODE" == "no_full_backup" ]]; then
    echo "No full backup exists | color=#FF3B30 size=14"
elif [[ "$SUMMARY_STATUS_CODE" == "backup_delayed" || "$SUMMARY_STATUS_CODE" == "backup_delayed_proof_stale" ]]; then
    echo "${DISPLAY_NAME} status: waiting for next automatic run | color=${WARNING_TEXT_COLOR} size=14"
    if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    if [[ -n "$SUMMARY_NEXT_RUN_LABEL" ]]; then
        echo "  Next automatic run: ${SUMMARY_NEXT_RUN_LABEL} | size=13"
    elif [[ -n "$SUMMARY_NEXT_RUN_DETAIL" ]]; then
        echo "  Next automatic run: ${SUMMARY_NEXT_RUN_DETAIL} | size=13"
    fi
    echo "  No failure is recorded. This usually catches up on the next wake or scheduled cycle. | size=13 color=#666"
    if [[ "$SUMMARY_STATUS_CODE" == "backup_delayed_proof_stale" ]]; then
        echo "  Integrity check: ${VERIFY_CHECK_AGE} | size=13"
        echo "  Restore drill: ${VERIFY_RESTORE_AGE} | size=13"
    fi
elif [[ "$SUMMARY_STATUS_CODE" == "backup_overdue" ]]; then
    echo "${DISPLAY_NAME} status: action recommended | color=${CRITICAL_TEXT_COLOR} size=14"
    if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
        echo "  Last full backup: ${SUMMARY_LATEST_FULL_AGE} | size=13"
    fi
    if [[ -n "$SUMMARY_NEXT_RUN_LABEL" ]]; then
        echo "  Next automatic run: ${SUMMARY_NEXT_RUN_LABEL} | size=13"
    elif [[ -n "$SUMMARY_NEXT_RUN_DETAIL" ]]; then
        echo "  Next automatic run: ${SUMMARY_NEXT_RUN_DETAIL} | size=13"
    fi
    echo "  No active failure is recorded, but backup age is past the quiet window. | size=13 color=#666"
else
    if [[ "$SUMMARY_STATUS_CODE" == "verification_failed" ]]; then
        echo "${DISPLAY_NAME} status: recovery proof failed | color=${CRITICAL_TEXT_COLOR} size=14"
        if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
            echo "  Last backup: ${SUMMARY_LATEST_FULL_AGE}${BACKUP_LINE_SUFFIX} | size=13"
        fi
        echo "  ${SUMMARY_STATUS_DETAIL} | size=13"
    elif [[ "$SUMMARY_STATUS_HEALTH" == "ok" ]]; then
        if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
            echo "Last backup: ${SUMMARY_LATEST_FULL_AGE}${BACKUP_LINE_SUFFIX} | size=14"
        else
            echo "Last backup: recent${BACKUP_LINE_SUFFIX} | size=14"
        fi
        echo "  Integrity check: ${VERIFY_CHECK_AGE}${VERIFY_CHECK_LINE_SUFFIX} | size=13"
        echo "  Restore drill: ${VERIFY_RESTORE_AGE}${VERIFY_RESTORE_LINE_SUFFIX} | size=13"
        echo "  Snapshot ${SUMMARY_LATEST_FULL_SNAPSHOT} | font=Menlo size=12 color=#888"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_proof_stale" ]]; then
        echo "${DISPLAY_NAME} status: backup healthy, recovery proof stale | color=${WARNING_TEXT_COLOR} size=14"
        if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
            echo "  Last backup: ${SUMMARY_LATEST_FULL_AGE}${BACKUP_LINE_SUFFIX} | size=13"
        fi
        echo "  Integrity check: ${VERIFY_CHECK_AGE}${VERIFY_CHECK_LINE_SUFFIX} | size=13"
        echo "  Restore drill: ${VERIFY_RESTORE_AGE}${VERIFY_RESTORE_LINE_SUFFIX} | size=13"
    else
        echo "${DISPLAY_NAME} status: ${SUMMARY_STATUS_TEXT} | color=${WARNING_TEXT_COLOR} size=14"
        if [[ -n "$SUMMARY_LATEST_FULL_AGE" ]]; then
            echo "  Last backup: ${SUMMARY_LATEST_FULL_AGE}${BACKUP_LINE_SUFFIX} | size=13"
        fi
        echo "  Integrity check: ${VERIFY_CHECK_AGE}${VERIFY_CHECK_LINE_SUFFIX} | size=13"
        echo "  Restore drill: ${VERIFY_RESTORE_AGE}${VERIFY_RESTORE_LINE_SUFFIX} | size=13"
        echo "  ${SUMMARY_STATUS_DETAIL} | size=13 color=#888"
    fi
fi

echo "---"

# section 2: actions

section_label "Actions"

if [[ "$UPLOAD_STATE" == "running" ]]; then
    echo "Pause upload | bash=/bin/bash param1=-lc param2=$(swiftbar_shell_command "pkill -STOP -f \"$BACKUP_PROCESS_MATCH\"") terminal=false refresh=true"
elif [[ "$UPLOAD_STATE" == "paused" ]]; then
    echo "Resume upload | bash=/bin/bash param1=-lc param2=$(swiftbar_shell_command "pkill -CONT -f \"$BACKUP_PROCESS_MATCH\"") terminal=false refresh=true color=#34C759"
else
    PRIMARY_ACTION_KIND="backup"
    PRIMARY_ACTION_LABEL="Run backup now"
    PRIMARY_ACTION_COMMAND="$BACKUP_COMMAND"
    PRIMARY_ACTION_PARAM1=""
    PRIMARY_ACTION_PARAM2=""
    PRIMARY_ACTION_TERMINAL="true"
    PRIMARY_ACTION_COLOR=""

    if [[ "$LAUNCHD_LOADED" -eq 0 && -n "$SCHEDULER_PLIST" ]]; then
        PRIMARY_ACTION_KIND="schedule"
        PRIMARY_ACTION_LABEL="Fix now: Resume automatic backups"
        PRIMARY_ACTION_COMMAND="/bin/bash"
        PRIMARY_ACTION_PARAM1="-lc"
        PRIMARY_ACTION_PARAM2="$(swiftbar_shell_command "launchctl load \"$SCHEDULER_PLIST\"")"
        PRIMARY_ACTION_TERMINAL="false"
        PRIMARY_ACTION_COLOR=" color=#34C759"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_proof_stale" || "$SUMMARY_STATUS_CODE" == "backup_delayed_proof_stale" || "$SUMMARY_STATUS_CODE" == "verification_failed" ]]; then
        PRIMARY_ACTION_KIND="verify"
        PRIMARY_ACTION_LABEL="Fix now: Run integrity check + restore drill"
        PRIMARY_ACTION_COMMAND="$VERIFY_COMMAND"
        PRIMARY_ACTION_PARAM1="--force"
        PRIMARY_ACTION_COLOR=" color=#34C759"
    elif [[ "$SUMMARY_STATUS_CODE" == "backup_delayed" || "$SUMMARY_STATUS_CODE" == "backup_overdue" || "$SUMMARY_STATUS_CODE" == "retry_pending" || "$SUMMARY_STATUS_CODE" == "waiting_for_network" ]]; then
        PRIMARY_ACTION_LABEL="Fix now: Run backup now"
        PRIMARY_ACTION_COLOR=" color=#34C759"
    elif [[ "$SUMMARY_STATUS_CODE" == "no_full_backup" ]]; then
        PRIMARY_ACTION_LABEL="Fix now: Run first backup"
        PRIMARY_ACTION_COLOR=" color=#34C759"
    fi

    if [[ -n "$PRIMARY_ACTION_PARAM2" ]]; then
        echo "${PRIMARY_ACTION_LABEL} | bash=${PRIMARY_ACTION_COMMAND} param1=${PRIMARY_ACTION_PARAM1} param2=${PRIMARY_ACTION_PARAM2} terminal=${PRIMARY_ACTION_TERMINAL} refresh=true${PRIMARY_ACTION_COLOR}"
    elif [[ -n "$PRIMARY_ACTION_PARAM1" ]]; then
        echo "${PRIMARY_ACTION_LABEL} | bash=${PRIMARY_ACTION_COMMAND} param1=${PRIMARY_ACTION_PARAM1} terminal=${PRIMARY_ACTION_TERMINAL} refresh=true${PRIMARY_ACTION_COLOR}"
    else
        echo "${PRIMARY_ACTION_LABEL} | bash=${PRIMARY_ACTION_COMMAND} terminal=${PRIMARY_ACTION_TERMINAL} refresh=true${PRIMARY_ACTION_COLOR}"
    fi
fi

if [[ "$UPLOAD_STATE" == "none" ]]; then
    if [[ "${PRIMARY_ACTION_KIND:-backup}" != "backup" ]]; then
        echo "Run backup now | bash=$BACKUP_COMMAND terminal=true refresh=true"
    fi
    if [[ "${PRIMARY_ACTION_KIND:-backup}" != "verify" ]]; then
        echo "Run integrity check + restore drill | bash=$VERIFY_COMMAND param1=--force terminal=true refresh=true"
    fi
fi

if [[ -n "$SCHEDULER_PLIST" ]]; then
    if [[ "$LAUNCHD_LOADED" -gt 0 ]]; then
        PAUSE_CMD="launchctl unload \"$SCHEDULER_PLIST\""
        echo "Pause schedule | bash=/bin/bash param1=-lc param2=$(swiftbar_shell_command "$PAUSE_CMD") terminal=false refresh=true"
    else
        RESUME_CMD="launchctl load \"$SCHEDULER_PLIST\""
        echo "Resume schedule | bash=/bin/bash param1=-lc param2=$(swiftbar_shell_command "$RESUME_CMD") terminal=false refresh=true color=#34C759"
    fi
fi

echo "---"

# section 3: system info

section_label "System"

echo "Destination: ${SYSTEM3_BACKUP_STORAGE_LABEL} | size=13 color=#888"
echo "Schedule: ${SYSTEM3_BACKUP_SCHEDULE_LABEL} | size=13 color=#888"
echo "Recovery proof: ${SYSTEM3_BACKUP_CHECK_INTERVAL_DAYS}d integrity check + ${SYSTEM3_BACKUP_RESTORE_INTERVAL_DAYS}d test restore | size=13 color=#888"
echo "  Reads backup data for corruption and test-restores a canary file. | size=12 color=#888"
echo "Encryption: ${SYSTEM3_BACKUP_ENCRYPTION_LABEL} | size=13 color=#888"

echo "---"

# section 4: links and tools

section_label "Open"

if [[ -n "$DASHBOARD_COMMAND" && -n "$DASHBOARD_OUTPUT" ]]; then
    OPEN_DASHBOARD_CMD="\"$DASHBOARD_COMMAND\" && open \"$DASHBOARD_OUTPUT\""
    echo "Open ${DISPLAY_NAME} dashboard | bash=/bin/bash param1=-lc param2=$(swiftbar_shell_command "$OPEN_DASHBOARD_CMD") terminal=false refresh=true"
fi

if [[ -n "$HC_DETAILS_URL" ]]; then
    echo "Open ${SYSTEM3_BACKUP_MONITOR_LABEL} details | href=${HC_DETAILS_URL}"
fi

if [[ -n "$STORAGE_URL" ]]; then
    echo "Open storage console | href=${STORAGE_URL}"
fi

LATEST_LOG="$(ls -t "$SYSTEM3_BACKUP_LOG_DIR"/backup-*.log 2>/dev/null | head -1 || true)"
if [[ -n "$LATEST_LOG" ]]; then
    echo "Open latest backup log | bash=/usr/bin/open param1=$LATEST_LOG terminal=false"
fi

echo "---"
echo "Refresh this menu | refresh=true"
