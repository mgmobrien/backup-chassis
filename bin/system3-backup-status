#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
STATUS_DATA_COMMAND="${SYSTEM3_BACKUP_STATUS_DATA_COMMAND:-$SCRIPT_DIR/system3-backup-status-data}"

MODE="text"

usage() {
    cat <<EOF
Usage: system3-backup-status [--json]

Reads the current state files and prints a concise operator status.

Options:
  --json      Emit machine-readable JSON
  -h, --help  Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --json)
            MODE="json"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

SUMMARY_JSON="$("$STATUS_DATA_COMMAND")"

if [[ "$MODE" == "json" ]]; then
    SUMMARY_JSON="$SUMMARY_JSON" python3 <<'PY'
import json
import os

data = json.loads(os.environ["SUMMARY_JSON"])
print(json.dumps(data, indent=2, sort_keys=True))
PY
else
    SUMMARY_JSON="$SUMMARY_JSON" python3 <<'PY'
import json
import os

data = json.loads(os.environ["SUMMARY_JSON"])
print(f"{data.get('display_name', 'Backup')}: {data.get('status_text', 'Backup overdue')}")
print(data.get("status_detail", ""))
snapshot = data.get("latest_full_snapshot", "")
if snapshot:
    print(f"Snapshot {snapshot}")
next_run = data.get("next_run_detail", "")
if next_run:
    print(f"Next automatic run: {next_run}")
print(f"Verification: {data.get('verify_text', 'No verification record')}")
PY
fi

EXIT_CODE="$(
    SUMMARY_JSON="$SUMMARY_JSON" python3 <<'PY'
import json
import os

data = json.loads(os.environ["SUMMARY_JSON"])
health = data.get("status_health", "critical")
if health in ("ok", "running"):
    print(0)
elif health == "warning":
    print(1)
else:
    print(2)
PY
)"
exit "$EXIT_CODE"
