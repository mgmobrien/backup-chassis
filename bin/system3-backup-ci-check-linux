#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"

echo "portable-core doctor"
"$REPO_ROOT/bin/system3-backup-doctor" --portable-core

echo
echo "linux adapter doctor"
"$REPO_ROOT/bin/system3-backup-doctor" --linux-adapter

echo
echo "shell syntax"
while IFS= read -r candidate; do
    bash -n "$candidate"
    echo "ok  $candidate"
done < <(find "$REPO_ROOT/bin" -maxdepth 1 -type f | sort)

echo
echo "linux smoke test"
"$REPO_ROOT/bin/system3-backup" smoke-test --platform linux
