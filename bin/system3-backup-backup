#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/system3-backup-env.sh"
system3_backup_load_env
system3_backup_require_runtime_credentials
system3_backup_require_env SYSTEM3_BACKUP_PATHS_FILE

MODE="${1:---run}"
LOGFILE="$SYSTEM3_BACKUP_LOG_DIR/backup-$(date +%Y-%m-%d_%H%M%S).log"
STATUS_FILE="$SYSTEM3_BACKUP_STATUS_FILE"
SNAPSHOTS_CACHE_FILE="$SYSTEM3_BACKUP_SNAPSHOTS_CACHE_FILE"
FAIL_COUNT_FILE="$SYSTEM3_BACKUP_FAIL_COUNT_FILE"
PIDFILE="${TMPDIR:-/tmp}/system3-backup.pid"
VERIFY_SCRIPT="${SYSTEM3_BACKUP_VERIFY_SCRIPT:-$SCRIPT_DIR/system3-backup-verify}"

declare -a BACKUP_PATHS=()

validate_optional_script() {
    local label="$1"
    local path="$2"

    if [[ -z "$path" || -x "$path" ]]; then
        return 0
    fi

    printf '%s is configured but not executable: %s\n' "$label" "$path" >&2
    return 1
}

cleanup() {
    rm -f "$PIDFILE"
}
trap cleanup EXIT

notify_local_failure() {
    local detail="$1"
    if [[ -n "${SYSTEM3_BACKUP_FAILURE_NOTIFY_SCRIPT:-}" ]]; then
        "$SYSTEM3_BACKUP_FAILURE_NOTIFY_SCRIPT" "$detail" "$SYSTEM3_BACKUP_DISPLAY_NAME" >/dev/null 2>&1 || true
    fi
}

ensure_canary() {
    mkdir -p "$(dirname "$SYSTEM3_BACKUP_CANARY_FILE")"
    if [[ ! -f "$SYSTEM3_BACKUP_CANARY_FILE" ]]; then
        printf '%s\n' \
            'Backup restore canary' \
            'Do not edit this file unless you intentionally want to change the restore baseline.' \
            'Version: 1' \
            'Created to prove that restores still return exact bytes on demand.' \
            > "$SYSTEM3_BACKUP_CANARY_FILE"
    fi
}

append_backup_path_if_missing() {
    local candidate="$1"
    local existing=""
    for existing in "${BACKUP_PATHS[@]}"; do
        if [[ "$existing" == "$candidate" ]]; then
            return
        fi
    done
    BACKUP_PATHS+=("$candidate")
}

load_backup_paths() {
    if [[ ! -f "$SYSTEM3_BACKUP_PATHS_FILE" ]]; then
        echo "Configured paths file not found: $SYSTEM3_BACKUP_PATHS_FILE" >&2
        return 1
    fi

    local resolved_path=""
    while IFS= read -r resolved_path; do
        [[ -z "$resolved_path" ]] && continue
        if [[ -e "$resolved_path" ]]; then
            BACKUP_PATHS+=("$resolved_path")
            continue
        fi

        if [[ "$SYSTEM3_BACKUP_ALLOW_MISSING_PATHS" == "1" ]]; then
            system3_backup_log "Skipping missing configured path: $resolved_path"
            continue
        fi

        echo "Configured backup path not found: $resolved_path" >&2
        return 1
    done < <(
        python3 - "$SYSTEM3_BACKUP_PATHS_FILE" <<'PY'
import os
import sys

path_file = sys.argv[1]
with open(path_file) as handle:
    for raw in handle:
        line = raw.strip()
        if not line or line.startswith("#"):
            continue
        print(os.path.expandvars(os.path.expanduser(line)))
PY
    )

    ensure_canary
    append_backup_path_if_missing "$SYSTEM3_BACKUP_CANARY_FILE"

    if (( ${#BACKUP_PATHS[@]} == 0 )); then
        echo "No backup paths resolved from $SYSTEM3_BACKUP_PATHS_FILE" >&2
        return 1
    fi
}

current_fail_count() {
    if [[ -f "$FAIL_COUNT_FILE" ]]; then
        cat "$FAIL_COUNT_FILE" 2>/dev/null || echo 0
        return
    fi
    echo 0
}

write_status() {
    export S3B_STATUS_FILE="$STATUS_FILE"
    export S3B_STATE="${1:-}"
    export S3B_PHASE="${2:-}"
    export S3B_DETAIL="${3:-}"
    export S3B_FAILURES="$(current_fail_count)"
    export S3B_NEXT_ATTEMPT="${4:-}"
    export S3B_SNAPSHOT_ID="${5:-}"
    export S3B_COMPLETED_AT="${6:-}"
    python3 <<'PY'
import json
import os
from datetime import datetime, timezone

path = os.environ["S3B_STATUS_FILE"]
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        data = {}

data.update({
    "state": os.environ.get("S3B_STATE", ""),
    "phase": os.environ.get("S3B_PHASE", ""),
    "detail": os.environ.get("S3B_DETAIL", ""),
    "failures": int(os.environ.get("S3B_FAILURES", "0")),
    "updated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
})
next_attempt = os.environ.get("S3B_NEXT_ATTEMPT", "")
snapshot_id = os.environ.get("S3B_SNAPSHOT_ID", "")
completed_at = os.environ.get("S3B_COMPLETED_AT", "")
if next_attempt:
    data["next_attempt"] = next_attempt
if snapshot_id:
    data["snapshot_id"] = snapshot_id
if completed_at:
    data["completed_at"] = completed_at

with open(path, "w") as f:
    json.dump(data, f)
PY
}

run_network_precheck() {
    if [[ -z "$SYSTEM3_BACKUP_NETWORK_CHECK_URL" ]]; then
        return 0
    fi

    local http_code
    http_code="$(curl -sS -m 10 --connect-timeout 5 -o /dev/null -w '%{http_code}' "$SYSTEM3_BACKUP_NETWORK_CHECK_URL" 2>/dev/null || echo 000)"
    if [[ "$http_code" != "000" ]]; then
        return 0
    fi

    local next_attempt
    next_attempt="$(system3_backup_iso_utc_in_future "$SYSTEM3_BACKUP_SCHEDULE_INTERVAL_SECONDS")"
    export S3B_WAIT_STATUS_FILE="$STATUS_FILE"
    export S3B_WAIT_FAILURES="$(current_fail_count)"
    export S3B_WAIT_NEXT_ATTEMPT="$next_attempt"
    export S3B_WAIT_HTTP_CODE="$http_code"
    python3 <<'PY'
import json
import os
from datetime import datetime, timezone

status = {
    "state": "waiting_for_network",
    "phase": "backup",
    "failures": int(os.environ["S3B_WAIT_FAILURES"]),
    "next_attempt": os.environ["S3B_WAIT_NEXT_ATTEMPT"],
    "updated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "endpoint_http_code": os.environ["S3B_WAIT_HTTP_CODE"],
}
with open(os.environ["S3B_WAIT_STATUS_FILE"], "w") as f:
    json.dump(status, f)
PY
    system3_backup_log "Skipped: network precheck failed for $SYSTEM3_BACKUP_NETWORK_CHECK_URL. Will retry next scheduled run."
    return 1
}

snapshot_machine_state() {
    if [[ "$SYSTEM3_BACKUP_DUMP_BREWFILE" != "1" ]]; then
        return 0
    fi
    if ! command -v brew >/dev/null 2>&1; then
        return 0
    fi
    mkdir -p "$SYSTEM3_BACKUP_MACHINE_STATE_DIR"
    brew bundle dump --file="$SYSTEM3_BACKUP_MACHINE_STATE_DIR/Brewfile" --force 2>/dev/null || true
    system3_backup_log "Brewfile snapshot saved"
}

ping_healthchecks_start() {
    if [[ -n "${HEALTHCHECKS_PING_URL:-}" ]]; then
        curl -fsS -m 10 --retry 5 "${HEALTHCHECKS_PING_URL}/start" >/dev/null 2>&1 || true
    fi
}

ping_healthchecks_success() {
    if [[ -n "${HEALTHCHECKS_PING_URL:-}" ]]; then
        curl -fsS -m 10 --retry 5 "$HEALTHCHECKS_PING_URL" >/dev/null 2>&1 || true
    fi
}

ping_healthchecks_failure() {
    local detail="$1"
    if [[ -n "${HEALTHCHECKS_PING_URL:-}" ]]; then
        curl -fsS -m 10 --retry 5 "${HEALTHCHECKS_PING_URL}/fail" --data-raw "$detail" >/dev/null 2>&1 || true
    fi
}

record_failure() {
    local detail="$1"
    local phase="${2:-backup}"
    local fail_count
    fail_count="$(current_fail_count)"
    fail_count=$((fail_count + 1))
    echo "$fail_count" > "$FAIL_COUNT_FILE"
    local next_attempt
    next_attempt="$(system3_backup_iso_utc_in_future "$SYSTEM3_BACKUP_SCHEDULE_INTERVAL_SECONDS")"
    write_status "retry_pending" "$phase" "$detail" "$next_attempt"
    system3_backup_log "$detail"
    notify_local_failure "$detail (failure $fail_count)"
    if (( fail_count >= SYSTEM3_BACKUP_FAIL_ALERT_THRESHOLD )); then
        ping_healthchecks_failure "$detail ($fail_count consecutive failures)"
    fi
}

print_config_check() {
    printf 'mode=%s\n' "$MODE"
    printf 'env_file=%s\n' "$SYSTEM3_BACKUP_ENV_FILE"
    printf 'paths_file=%s\n' "$SYSTEM3_BACKUP_PATHS_FILE"
    printf 'excludes_file=%s\n' "$SYSTEM3_BACKUP_EXCLUDES_FILE"
    printf 'status_file=%s\n' "$STATUS_FILE"
    printf 'snapshots_cache_file=%s\n' "$SNAPSHOTS_CACHE_FILE"
    printf 'canary_file=%s\n' "$SYSTEM3_BACKUP_CANARY_FILE"
    printf 'run_wrapper_script=%s\n' "${SYSTEM3_BACKUP_RUN_WRAPPER_SCRIPT:-}"
    printf 'failure_notify_script=%s\n' "${SYSTEM3_BACKUP_FAILURE_NOTIFY_SCRIPT:-}"
    printf 'schedule_interval_seconds=%s\n' "$SYSTEM3_BACKUP_SCHEDULE_INTERVAL_SECONDS"
    printf 'retention=%s/%s/%s\n' "$SYSTEM3_BACKUP_KEEP_DAILY" "$SYSTEM3_BACKUP_KEEP_WEEKLY" "$SYSTEM3_BACKUP_KEEP_MONTHLY"
    printf 'paths:\n'
    local path=""
    for path in "${BACKUP_PATHS[@]}"; do
        printf ' - %s\n' "$path"
    done
}

if [[ "$MODE" != "--run" && "$MODE" != "--check-config" ]]; then
    echo "Usage: system3-backup-backup [--run|--check-config]" >&2
    exit 2
fi

if [[ -f "$PIDFILE" ]]; then
    OLD_PID="$(cat "$PIDFILE" 2>/dev/null || true)"
    if [[ -n "$OLD_PID" ]] && kill -0 "$OLD_PID" 2>/dev/null; then
        system3_backup_log "Another backup is already running (PID $OLD_PID). Exiting."
        exit 0
    fi
    rm -f "$PIDFILE"
fi
echo $$ > "$PIDFILE"

load_backup_paths
validate_optional_script "run wrapper script" "${SYSTEM3_BACKUP_RUN_WRAPPER_SCRIPT:-}"
validate_optional_script "failure notify script" "${SYSTEM3_BACKUP_FAILURE_NOTIFY_SCRIPT:-}"

if [[ "$MODE" == "--check-config" ]]; then
    print_config_check
    exit 0
fi

write_status "starting" "backup" "Backup starting"
system3_backup_log "Starting backup"
ping_healthchecks_start

if ! run_network_precheck; then
    exit 0
fi

restic unlock >/dev/null 2>&1 || true
snapshot_machine_state

declare -a BACKUP_CMD
BACKUP_CMD=(restic backup --json --one-file-system --exclude-caches --retry-lock 15m)
if [[ -f "$SYSTEM3_BACKUP_EXCLUDES_FILE" ]]; then
    BACKUP_CMD+=("--exclude-file=$SYSTEM3_BACKUP_EXCLUDES_FILE")
fi
BACKUP_CMD+=("${BACKUP_PATHS[@]}")

declare -a RUN_CMD
if [[ -n "${SYSTEM3_BACKUP_RUN_WRAPPER_SCRIPT:-}" ]]; then
    RUN_CMD=("$SYSTEM3_BACKUP_RUN_WRAPPER_SCRIPT" "${BACKUP_CMD[@]}")
else
    RUN_CMD=("${BACKUP_CMD[@]}")
fi

if ! "${RUN_CMD[@]}" 2>&1 | python3 -u -c "
import json
import time

status_file = '$STATUS_FILE'
log_file = '$LOGFILE'
last_log_time = 0

for line in __import__('sys').stdin:
    line_stripped = line.strip()
    if not line_stripped:
        continue
    try:
        msg = json.loads(line_stripped)
        mt = msg.get('message_type', '')
        if mt == 'status':
            pct = msg.get('percent_done', 0)
            total_bytes = msg.get('total_bytes', 0)
            bytes_done = msg.get('bytes_done', 0)
            total_files = msg.get('total_files', 0)
            files_done = msg.get('files_done', 0)
            gb_done = round(bytes_done / 1024**3, 1)
            gb_total = round(total_bytes / 1024**3)
            status = {
                'state': 'uploading',
                'phase': 'backup',
                'pct': round(pct * 100, 1),
                'gb_done': gb_done,
                'gb_total': gb_total,
                'bytes_done': bytes_done,
                'total_bytes_estimate': total_bytes,
                'files_done': files_done,
                'total_files': total_files,
                'total_files_estimate': total_files,
                'time': msg.get('seconds_elapsed', 0),
                'elapsed_s': msg.get('seconds_elapsed', 0),
                'updated_at': time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),
            }
            with open(status_file, 'w') as sf:
                json.dump(status, sf)
            now = time.time()
            if now - last_log_time >= 60:
                with open(log_file, 'a') as lf:
                    lf.write(
                        f\"Progress: {status['pct']}% — {files_done:,} / {total_files:,} files — {bytes_done} / {total_bytes} bytes\\n\"
                    )
                last_log_time = now
        elif mt == 'summary':
            with open(log_file, 'a') as lf:
                lf.write(line)
            status = {
                'state': 'complete',
                'phase': 'backup',
                'files_new': msg.get('files_new', 0),
                'files_changed': msg.get('files_changed', 0),
                'data_added': msg.get('data_added', 0),
                'total_files': msg.get('total_files_processed', 0),
                'total_bytes': msg.get('total_bytes_processed', 0),
                'duration': msg.get('total_duration', 0),
                'snapshot_id': msg.get('snapshot_id', ''),
                'completed_at': msg.get('backup_end', ''),
                'updated_at': time.strftime('%Y-%m-%dT%H:%M:%SZ', time.gmtime()),
            }
            with open(status_file, 'w') as sf:
                json.dump(status, sf)
        elif mt == 'error':
            with open(log_file, 'a') as lf:
                lf.write(line)
    except Exception:
        with open(log_file, 'a') as lf:
            lf.write(line)
"; then
    record_failure "restic backup failed" "backup"
    exit 1
fi

system3_backup_log "Backup complete. Applying retention policy."
restic unlock >/dev/null 2>&1 || true

if ! restic forget \
    --keep-daily "$SYSTEM3_BACKUP_KEEP_DAILY" \
    --keep-weekly "$SYSTEM3_BACKUP_KEEP_WEEKLY" \
    --keep-monthly "$SYSTEM3_BACKUP_KEEP_MONTHLY" \
    --prune \
    --verbose \
    2>&1 | tee -a "$LOGFILE"; then
    record_failure "restic forget/prune failed" "forget_prune"
    exit 1
fi

system3_backup_log "Retention policy applied."
restic snapshots --json > "$SNAPSHOTS_CACHE_FILE" 2>/dev/null || true

if [[ -x "$VERIFY_SCRIPT" ]]; then
    system3_backup_log "Checking whether recoverability verification is due..."
    if ! "$VERIFY_SCRIPT" --if-due 2>&1 | tee -a "$LOGFILE"; then
        record_failure "Backup verification failed" "verification"
        exit 1
    fi
fi

rm -f "$FAIL_COUNT_FILE"
ping_healthchecks_success

find "$SYSTEM3_BACKUP_LOG_DIR" \( -name "backup-*.log" -o -name "verify-*.log" \) -mtime +"$SYSTEM3_BACKUP_LOG_RETENTION_DAYS" -delete 2>/dev/null || true

system3_backup_log "Done."
