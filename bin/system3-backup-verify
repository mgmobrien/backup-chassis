#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
# shellcheck disable=SC1091
source "$SCRIPT_DIR/system3-backup-env.sh"
system3_backup_load_env
system3_backup_require_runtime_credentials

LOGFILE="$SYSTEM3_BACKUP_LOG_DIR/verify-$(date +%Y-%m-%d_%H%M%S).log"
STATUS_FILE="$SYSTEM3_BACKUP_STATUS_DIR/verification-status.json"
PIDFILE="${TMPDIR:-/tmp}/system3-backup-verify.pid"
PIDFILE="$SYSTEM3_BACKUP_VERIFY_PID_FILE"
MODE="${1:---if-due}"

cleanup() {
    rm -f "$PIDFILE"
    if [[ -n "${RESTORE_TMPDIR:-}" && -d "${RESTORE_TMPDIR:-}" ]]; then
        rm -rf "$RESTORE_TMPDIR" 2>/dev/null || true
    fi
}
trap cleanup EXIT

ensure_canary() {
    mkdir -p "$(dirname "$SYSTEM3_BACKUP_CANARY_FILE")"
    if [[ ! -f "$SYSTEM3_BACKUP_CANARY_FILE" ]]; then
        printf '%s\n' \
            'Backup restore canary' \
            'Do not edit this file unless you intentionally want to change the restore baseline.' \
            'Version: 1' \
            'Created to prove that restores still return exact bytes on demand.' \
            > "$SYSTEM3_BACKUP_CANARY_FILE"
    fi
}

write_status() {
    export S3B_VERIFY_STATUS_FILE="$STATUS_FILE"
    export S3B_VERIFY_STATE="${1:-}"
    export S3B_VERIFY_PHASE="${2:-}"
    export S3B_VERIFY_DETAIL="${3:-}"
    export S3B_VERIFY_SNAPSHOT_ID="${4:-}"
    export S3B_VERIFY_SNAPSHOT_TIME="${5:-}"
    export S3B_VERIFY_LAST_CHECK_OK_AT="${LAST_CHECK_OK_AT:-}"
    export S3B_VERIFY_LAST_RESTORE_OK_AT="${LAST_RESTORE_OK_AT:-}"
    export S3B_VERIFY_LAST_FAILURE_AT="${LAST_FAILURE_AT:-}"
    export S3B_VERIFY_LAST_FAILURE_DETAIL="${LAST_FAILURE_DETAIL:-}"
    export S3B_VERIFY_CANARY_FILE="$SYSTEM3_BACKUP_CANARY_FILE"
    export S3B_VERIFY_CHECK_SUBSET="$SYSTEM3_BACKUP_CHECK_SUBSET"
    export S3B_VERIFY_CHECK_INTERVAL_DAYS="$SYSTEM3_BACKUP_CHECK_INTERVAL_DAYS"
    export S3B_VERIFY_RESTORE_INTERVAL_DAYS="$SYSTEM3_BACKUP_RESTORE_INTERVAL_DAYS"
    python3 <<'PY'
import json
import os
from datetime import datetime, timedelta, timezone

path = os.environ["S3B_VERIFY_STATUS_FILE"]
data = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            data = json.load(f)
    except Exception:
        data = {}

def parse_time(value: str):
    if not value:
        return None
    raw = value.replace("Z", "")
    for fmt in ("%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M:%S.%f"):
        try:
            return datetime.strptime(raw, fmt)
        except ValueError:
            continue
    return None

now = datetime.now(timezone.utc).replace(tzinfo=None, microsecond=0)
state = os.environ.get("S3B_VERIFY_STATE", "")
phase = os.environ.get("S3B_VERIFY_PHASE", "")
detail = os.environ.get("S3B_VERIFY_DETAIL", "")
snapshot_id = os.environ.get("S3B_VERIFY_SNAPSHOT_ID", "")
snapshot_time = os.environ.get("S3B_VERIFY_SNAPSHOT_TIME", "")
last_check_ok_at = os.environ.get("S3B_VERIFY_LAST_CHECK_OK_AT", "")
last_restore_ok_at = os.environ.get("S3B_VERIFY_LAST_RESTORE_OK_AT", "")
last_failure_at = os.environ.get("S3B_VERIFY_LAST_FAILURE_AT", "")
last_failure_detail = os.environ.get("S3B_VERIFY_LAST_FAILURE_DETAIL", "")

data.update({
    "state": state,
    "phase": phase,
    "detail": detail,
    "last_run_at": now.isoformat() + "Z",
    "check_subset": os.environ.get("S3B_VERIFY_CHECK_SUBSET", ""),
    "check_interval_days": int(os.environ.get("S3B_VERIFY_CHECK_INTERVAL_DAYS", "7")),
    "restore_interval_days": int(os.environ.get("S3B_VERIFY_RESTORE_INTERVAL_DAYS", "30")),
    "canary_path": os.environ.get("S3B_VERIFY_CANARY_FILE", ""),
})
if snapshot_id:
    data["last_snapshot_id"] = snapshot_id
if snapshot_time:
    data["last_snapshot_time"] = snapshot_time
if last_check_ok_at:
    data["last_check_ok_at"] = last_check_ok_at
if last_restore_ok_at:
    data["last_restore_ok_at"] = last_restore_ok_at
if last_failure_at:
    data["last_failure_at"] = last_failure_at
if last_failure_detail:
    data["last_failure_detail"] = last_failure_detail
if state == "ok":
    data["last_success_at"] = now.isoformat() + "Z"
    data.pop("last_failure_at", None)
    data.pop("last_failure_detail", None)

check_dt = parse_time(data.get("last_check_ok_at", ""))
restore_dt = parse_time(data.get("last_restore_ok_at", ""))
check_due_days = data.get("check_interval_days", 7)
restore_due_days = data.get("restore_interval_days", 30)
if check_dt:
    data["next_check_due_at"] = (check_dt + timedelta(days=check_due_days)).isoformat() + "Z"
if restore_dt:
    data["next_restore_due_at"] = (restore_dt + timedelta(days=restore_due_days)).isoformat() + "Z"

with open(path, "w") as f:
    json.dump(data, f)
PY
}

load_due_flags() {
    export S3B_VERIFY_STATUS_FILE="$STATUS_FILE"
    python3 <<'PY'
import json
import os
from datetime import datetime, timedelta, timezone

path = os.environ["S3B_VERIFY_STATUS_FILE"]
now = datetime.now(timezone.utc).replace(tzinfo=None)
status = {}
if os.path.exists(path):
    try:
        with open(path) as f:
            status = json.load(f)
    except Exception:
        status = {}

def parse_time(value: str):
    if not value:
        return None
    raw = value.replace("Z", "")
    for fmt in ("%Y-%m-%dT%H:%M:%S", "%Y-%m-%dT%H:%M:%S.%f"):
        try:
            return datetime.strptime(raw, fmt)
        except ValueError:
            continue
    return None

check_dt = parse_time(status.get("last_check_ok_at", ""))
restore_dt = parse_time(status.get("last_restore_ok_at", ""))
check_due = check_dt is None or (now - check_dt) >= timedelta(days=int(status.get("check_interval_days", 7)))
restore_due = restore_dt is None or (now - restore_dt) >= timedelta(days=int(status.get("restore_interval_days", 30)))
print("1" if check_due else "0")
print("1" if restore_due else "0")
print(status.get("last_check_ok_at", ""))
print(status.get("last_restore_ok_at", ""))
PY
}

fail_verification() {
    LAST_FAILURE_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    LAST_FAILURE_DETAIL="$1"
    system3_backup_log "$1"
    write_status "failed" "${2:-}" "$1" "${LATEST_SHORT_ID:-}" "${LATEST_TIME:-}"
    exit 1
}

latest_snapshot_info() {
    export S3B_SNAPSHOT_MATCH_PATH="$SYSTEM3_BACKUP_SNAPSHOT_MATCH_PATH"
    restic snapshots --json | python3 <<'PY'
import json
import os
import sys

data = json.load(sys.stdin)
match_path = os.environ.get("S3B_SNAPSHOT_MATCH_PATH", "")
data.sort(key=lambda snap: snap["time"], reverse=True)

for snap in data:
    paths = snap.get("paths", [])
    if match_path and match_path not in paths:
        continue
    print(snap["id"])
    print(snap["short_id"])
    print(snap["time"])
    break
PY
}

ensure_canary

if [[ "$MODE" != "--if-due" && "$MODE" != "--force" ]]; then
    echo "Usage: system3-backup-verify [--if-due|--force]" >&2
    exit 2
fi

if [[ -f "$PIDFILE" ]]; then
    OLD_PID="$(cat "$PIDFILE" 2>/dev/null || true)"
    if [[ -n "$OLD_PID" ]] && kill -0 "$OLD_PID" 2>/dev/null; then
        system3_backup_log "Another verification run is already active (PID $OLD_PID). Exiting."
        exit 0
    fi
    rm -f "$PIDFILE"
fi
echo $$ > "$PIDFILE"

if pgrep -f "restic backup" >/dev/null 2>&1; then
    system3_backup_log "Backup is currently running; verification skipped."
    exit 0
fi

DUE_INFO="$(load_due_flags)"
CHECK_DUE="$(echo "$DUE_INFO" | sed -n '1p')"
RESTORE_DUE="$(echo "$DUE_INFO" | sed -n '2p')"
LAST_CHECK_OK_AT="$(echo "$DUE_INFO" | sed -n '3p')"
LAST_RESTORE_OK_AT="$(echo "$DUE_INFO" | sed -n '4p')"

if [[ "$MODE" == "--force" ]]; then
    CHECK_DUE=1
    RESTORE_DUE=1
fi

if [[ "$CHECK_DUE" != "1" && "$RESTORE_DUE" != "1" ]]; then
    system3_backup_log "Verification not due."
    exit 0
fi

SNAP_INFO="$(latest_snapshot_info 2>/dev/null)"
LATEST_ID="$(echo "$SNAP_INFO" | sed -n '1p')"
LATEST_SHORT_ID="$(echo "$SNAP_INFO" | sed -n '2p')"
LATEST_TIME="$(echo "$SNAP_INFO" | sed -n '3p')"

if [[ -z "$LATEST_ID" ]]; then
    if [[ -n "$SYSTEM3_BACKUP_SNAPSHOT_MATCH_PATH" ]]; then
        fail_verification "Verification could not find a snapshot matching $SYSTEM3_BACKUP_SNAPSHOT_MATCH_PATH." "snapshot_lookup"
    fi
    fail_verification "Verification could not find a completed snapshot." "snapshot_lookup"
fi

system3_backup_log "Starting Backup verification against snapshot ${LATEST_SHORT_ID}"
write_status "running" "starting" "Verification started" "$LATEST_SHORT_ID" "$LATEST_TIME"

restic unlock >/dev/null 2>&1 || true

if [[ "$CHECK_DUE" == "1" ]]; then
    write_status "running" "integrity_check" "Running restic check --read-data-subset=${SYSTEM3_BACKUP_CHECK_SUBSET}" "$LATEST_SHORT_ID" "$LATEST_TIME"
    system3_backup_log "Running integrity check (${SYSTEM3_BACKUP_CHECK_SUBSET})"
    if ! restic check --read-data-subset="$SYSTEM3_BACKUP_CHECK_SUBSET" 2>&1 | tee -a "$LOGFILE"; then
        fail_verification "Integrity check failed." "integrity_check"
    fi
    LAST_CHECK_OK_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    system3_backup_log "Integrity check passed"
fi

if [[ "$RESTORE_DUE" == "1" ]]; then
    write_status "running" "restore_drill" "Restoring canary file from snapshot ${LATEST_SHORT_ID}" "$LATEST_SHORT_ID" "$LATEST_TIME"
    system3_backup_log "Running restore drill for $(basename "$SYSTEM3_BACKUP_CANARY_FILE")"
    RESTORE_TMPDIR="$(mktemp -d "${TMPDIR:-/tmp}/system3-backup-verify.XXXXXX")"
    CANARY_HASH="$(shasum -a 256 "$SYSTEM3_BACKUP_CANARY_FILE" | awk '{print $1}')"
    if ! restic restore "$LATEST_ID" --target "$RESTORE_TMPDIR" --include "$SYSTEM3_BACKUP_CANARY_FILE" 2>&1 | tee -a "$LOGFILE"; then
        fail_verification "Restore drill failed while restoring the canary file." "restore_drill"
    fi
    RESTORED_CANARY="$RESTORE_TMPDIR$SYSTEM3_BACKUP_CANARY_FILE"
    if [[ ! -f "$RESTORED_CANARY" ]]; then
        fail_verification "Restore drill did not produce the canary file in the restore target." "restore_drill"
    fi
    RESTORED_HASH="$(shasum -a 256 "$RESTORED_CANARY" | awk '{print $1}')"
    if [[ "$CANARY_HASH" != "$RESTORED_HASH" ]]; then
        fail_verification "Restore drill hash mismatch for the canary file." "restore_drill"
    fi
    LAST_RESTORE_OK_AT="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    system3_backup_log "Restore drill passed"
fi

SUCCESS_DETAIL="Verification passed"
if [[ "$CHECK_DUE" == "1" && "$RESTORE_DUE" == "1" ]]; then
    SUCCESS_DETAIL="Integrity check and restore drill passed"
elif [[ "$CHECK_DUE" == "1" ]]; then
    SUCCESS_DETAIL="Integrity check passed"
elif [[ "$RESTORE_DUE" == "1" ]]; then
    SUCCESS_DETAIL="Restore drill passed"
fi

write_status "ok" "complete" "$SUCCESS_DETAIL" "$LATEST_SHORT_ID" "$LATEST_TIME"
system3_backup_log "$SUCCESS_DETAIL"
