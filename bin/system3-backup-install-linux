#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
# shellcheck disable=SC1091
source "$REPO_ROOT/bin/system3-backup-env.sh"

CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}/system3-backup"
STATE_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/system3-backup"
LOG_DIR="${XDG_STATE_HOME:-$HOME/.local/state}/system3-backup/log"
DASHBOARD_DIR="${XDG_DATA_HOME:-$HOME/.local/share}/system3-backup"
DASHBOARD_OUTPUT="$DASHBOARD_DIR/index.html"
SYSTEMD_USER_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/systemd/user"
SYSTEMD_SERVICE_PATH="$SYSTEMD_USER_DIR/system3-backup.service"
SYSTEMD_TIMER_PATH="$SYSTEMD_USER_DIR/system3-backup.timer"
SERVICE_LABEL="system3-backup.service"
DISPLAY_NAME="Backup"
SCHEDULE_INTERVAL_SECONDS="14400"
FORCE="0"

schedule_label_for_interval() {
    local interval_label
    interval_label="$(system3_backup_format_interval_label "$SCHEDULE_INTERVAL_SECONDS")"
    printf '%s + on user session' "$interval_label"
}

usage() {
    cat <<EOF
Usage: system3-backup-install-linux [options]

Creates a machine-local bootstrap surface for backup-chassis on Linux with
systemd --user scheduling.

Options:
  --config-home PATH                 Config directory (default: $CONFIG_HOME)
  --state-dir PATH                   State/status directory (default: $STATE_DIR)
  --log-dir PATH                     Log directory (default: $LOG_DIR)
  --dashboard-dir PATH               Dashboard directory (default: $DASHBOARD_DIR)
  --dashboard-output PATH            Dashboard HTML output path
  --systemd-user-dir PATH            systemd user-unit directory (default: $SYSTEMD_USER_DIR)
  --systemd-service-path PATH        systemd service output path
  --systemd-timer-path PATH          systemd timer output path
  --service-label LABEL              systemd service unit name
  --display-name NAME                Human-facing display name
  --schedule-interval-seconds N      systemd OnUnitActiveSec value in seconds (default: $SCHEDULE_INTERVAL_SECONDS)
  --force                            Overwrite existing generated files
  -h, --help                         Show this help
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --config-home)
            CONFIG_HOME="$2"
            shift 2
            ;;
        --state-dir)
            STATE_DIR="$2"
            shift 2
            ;;
        --log-dir)
            LOG_DIR="$2"
            shift 2
            ;;
        --dashboard-dir)
            DASHBOARD_DIR="$2"
            DASHBOARD_OUTPUT="$DASHBOARD_DIR/index.html"
            shift 2
            ;;
        --dashboard-output)
            DASHBOARD_OUTPUT="$2"
            DASHBOARD_DIR="$(dirname "$DASHBOARD_OUTPUT")"
            shift 2
            ;;
        --systemd-user-dir)
            SYSTEMD_USER_DIR="$2"
            SYSTEMD_SERVICE_PATH="$SYSTEMD_USER_DIR/system3-backup.service"
            SYSTEMD_TIMER_PATH="$SYSTEMD_USER_DIR/system3-backup.timer"
            shift 2
            ;;
        --systemd-service-path)
            SYSTEMD_SERVICE_PATH="$2"
            shift 2
            ;;
        --systemd-timer-path)
            SYSTEMD_TIMER_PATH="$2"
            shift 2
            ;;
        --service-label)
            SERVICE_LABEL="$2"
            shift 2
            ;;
        --display-name)
            DISPLAY_NAME="$2"
            shift 2
            ;;
        --schedule-interval-seconds)
            SCHEDULE_INTERVAL_SECONDS="$2"
            shift 2
            ;;
        --force)
            FORCE="1"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

resolve_path() {
    python3 - "$1" <<'PY'
import os
import sys

print(os.path.abspath(os.path.expanduser(sys.argv[1])))
PY
}

echo "check prerequisites"
"$REPO_ROOT/bin/system3-backup-doctor" --linux-adapter

if ! [[ "$SCHEDULE_INTERVAL_SECONDS" =~ ^[0-9]+$ ]] || [[ "$SCHEDULE_INTERVAL_SECONDS" -le 0 ]]; then
    echo "schedule interval must be a positive integer: $SCHEDULE_INTERVAL_SECONDS" >&2
    exit 2
fi

CONFIG_HOME="$(resolve_path "$CONFIG_HOME")"
STATE_DIR="$(resolve_path "$STATE_DIR")"
LOG_DIR="$(resolve_path "$LOG_DIR")"
DASHBOARD_DIR="$(resolve_path "$DASHBOARD_DIR")"
DASHBOARD_OUTPUT="$(resolve_path "$DASHBOARD_OUTPUT")"
SYSTEMD_USER_DIR="$(resolve_path "$SYSTEMD_USER_DIR")"
SYSTEMD_SERVICE_PATH="$(resolve_path "$SYSTEMD_SERVICE_PATH")"
SYSTEMD_TIMER_PATH="$(resolve_path "$SYSTEMD_TIMER_PATH")"

ENV_FILE="$CONFIG_HOME/system3-backup.env"
PATHS_FILE="$CONFIG_HOME/paths.txt"
EXCLUDES_FILE="$CONFIG_HOME/excludes.txt"
CANARY_FILE="$CONFIG_HOME/restore-canary-do-not-edit.txt"
MACHINE_STATE_DIR="$CONFIG_HOME/machine-state"

mkdir -p \
    "$CONFIG_HOME" \
    "$STATE_DIR" \
    "$LOG_DIR" \
    "$DASHBOARD_DIR" \
    "$SYSTEMD_USER_DIR"

write_file_if_allowed() {
    local target="$1"
    local mode="$2"

    if [[ -e "$target" && "$FORCE" != "1" ]]; then
        echo "skip  $target"
        return 0
    fi

    cat > "$target"
    chmod "$mode" "$target"
    echo "write $target"
}

copy_file_if_allowed() {
    local source_path="$1"
    local target="$2"
    local mode="$3"

    if [[ -e "$target" && "$FORCE" != "1" ]]; then
        echo "skip  $target"
        return 0
    fi

    cp "$source_path" "$target"
    chmod "$mode" "$target"
    echo "write $target"
}

write_file_if_allowed "$ENV_FILE" 0644 <<EOF
# Machine-local environment for backup-chassis
#
# Fill in the repository target and credentials before enabling the systemd timer.

# restic repository target
RESTIC_REPOSITORY="s3:s3.us-west-000.backblazeb2.com/example-bucket"

# Storage credentials for an S3-compatible backend.
# If you use a different restic backend, replace these with the vars that backend expects.
# If that backend needs additional env vars, list them in SYSTEM3_BACKUP_REQUIRED_RUNTIME_ENV_VARS.
AWS_ACCESS_KEY_ID="example-key-id"
AWS_SECRET_ACCESS_KEY="example-secret-key"
SYSTEM3_BACKUP_REQUIRED_RUNTIME_ENV_VARS=""

# Encryption passphrase
RESTIC_PASSWORD="replace-me"

# Optional heartbeat monitor
HEALTHCHECKS_PING_URL="https://hc-ping.example/uuid"
SYSTEM3_BACKUP_HEALTHCHECKS_CHECK_URL=""

# Local status paths
SYSTEM3_BACKUP_STATE_DIR="$STATE_DIR"
SYSTEM3_BACKUP_LOG_DIR="$LOG_DIR"
SYSTEM3_BACKUP_STATUS_DIR="$STATE_DIR"

# Local config files
SYSTEM3_BACKUP_PATHS_FILE="$PATHS_FILE"
SYSTEM3_BACKUP_EXCLUDES_FILE="$EXCLUDES_FILE"
SYSTEM3_BACKUP_CANARY_FILE="$CANARY_FILE"

# Scheduling and retention
SYSTEM3_BACKUP_SCHEDULE_INTERVAL_SECONDS="$SCHEDULE_INTERVAL_SECONDS"
SYSTEM3_BACKUP_FAIL_ALERT_THRESHOLD="3"
SYSTEM3_BACKUP_NETWORK_CHECK_URL=""
SYSTEM3_BACKUP_KEEP_DAILY="7"
SYSTEM3_BACKUP_KEEP_WEEKLY="4"
SYSTEM3_BACKUP_KEEP_MONTHLY="12"
SYSTEM3_BACKUP_LOG_RETENTION_DAYS="30"
SYSTEM3_BACKUP_ALLOW_MISSING_PATHS="0"
SYSTEM3_BACKUP_USE_CAFFEINATE="0"
SYSTEM3_BACKUP_DUMP_BREWFILE="0"
SYSTEM3_BACKUP_MACHINE_STATE_DIR="$MACHINE_STATE_DIR"
SYSTEM3_BACKUP_ENABLE_MACOS_NOTIFICATIONS="0"

# UI and display
SYSTEM3_BACKUP_DASHBOARD_DIR="$DASHBOARD_DIR"
SYSTEM3_BACKUP_DASHBOARD_OUTPUT="$DASHBOARD_OUTPUT"
SYSTEM3_BACKUP_DASHBOARD_ENTRYPOINT="$REPO_ROOT/bin/system3-backup-dashboard"
SYSTEM3_BACKUP_DISPLAY_NAME="$DISPLAY_NAME"
SYSTEM3_BACKUP_STORAGE_LABEL="\$RESTIC_REPOSITORY"
SYSTEM3_BACKUP_STORAGE_URL=""
SYSTEM3_BACKUP_SCHEDULER_LABEL="systemd --user"
SYSTEM3_BACKUP_SCHEDULE_LABEL="$(schedule_label_for_interval)"
SYSTEM3_BACKUP_SCHEDULER_SERVICE="$SERVICE_LABEL"
SYSTEM3_BACKUP_SCHEDULER_PLIST=""
SYSTEM3_BACKUP_MONITOR_LABEL="healthchecks.io"
SYSTEM3_BACKUP_ENCRYPTION_LABEL="restic repository encryption"
SYSTEM3_BACKUP_CREDENTIALS_LABEL="local machine credentials"
SYSTEM3_BACKUP_RUNTIME_ENTRYPOINT="$REPO_ROOT/bin/system3-backup-backup"
SYSTEM3_BACKUP_BACKUP_PROCESS_MATCH="restic backup"
SYSTEM3_BACKUP_VERIFY_SCRIPT="$REPO_ROOT/bin/system3-backup-verify"
SYSTEM3_BACKUP_VERIFY_PROCESS_MATCH="system3-backup-verify"

# Verification tuning
# Leave blank to use the first configured backup path automatically.
SYSTEM3_BACKUP_SNAPSHOT_MATCH_PATH=""
SYSTEM3_BACKUP_CHECK_SUBSET="1/16"
SYSTEM3_BACKUP_CHECK_INTERVAL_DAYS="7"
SYSTEM3_BACKUP_RESTORE_INTERVAL_DAYS="30"
EOF

copy_file_if_allowed "$REPO_ROOT/config/paths.example" "$PATHS_FILE" 0644
copy_file_if_allowed "$REPO_ROOT/config/excludes.example" "$EXCLUDES_FILE" 0644

write_file_if_allowed "$SYSTEMD_SERVICE_PATH" 0644 <<EOF
[Unit]
Description=$DISPLAY_NAME backup job
Wants=network-online.target
After=network-online.target

[Service]
Type=oneshot
WorkingDirectory=$REPO_ROOT
Environment=PATH=/usr/local/bin:/usr/bin:/bin
Environment=SYSTEM3_BACKUP_ENV_FILE=$ENV_FILE
ExecStart=$REPO_ROOT/bin/system3-backup-backup
Nice=10
IOSchedulingClass=best-effort
IOSchedulingPriority=7
EOF

write_file_if_allowed "$SYSTEMD_TIMER_PATH" 0644 <<EOF
[Unit]
Description=Run $DISPLAY_NAME backup periodically

[Timer]
OnBootSec=5m
OnUnitActiveSec=${SCHEDULE_INTERVAL_SECONDS}s
Persistent=true
Unit=$SERVICE_LABEL

[Install]
WantedBy=timers.target
EOF

validate_generated_surface() {
    local validation_env

    echo "validate $SYSTEMD_SERVICE_PATH"
    systemd-analyze verify "$SYSTEMD_SERVICE_PATH" "$SYSTEMD_TIMER_PATH" >/dev/null

    validation_env="$(mktemp "${TMPDIR:-/tmp}/system3-backup-install-linux-validate.XXXXXX")"
    python3 - "$ENV_FILE" "$validation_env" <<'PY'
import sys
from pathlib import Path

source_path = Path(sys.argv[1])
target_path = Path(sys.argv[2])
lines = source_path.read_text().splitlines()
found = False
output = []
for line in lines:
    if line.startswith("SYSTEM3_BACKUP_ALLOW_MISSING_PATHS="):
        output.append('SYSTEM3_BACKUP_ALLOW_MISSING_PATHS="1"')
        found = True
    else:
        output.append(line)
if not found:
    output.append('SYSTEM3_BACKUP_ALLOW_MISSING_PATHS="1"')
target_path.write_text("\n".join(output) + "\n")
PY

    echo "validate $ENV_FILE"
    SYSTEM3_BACKUP_ENV_FILE="$validation_env" "$REPO_ROOT/bin/system3-backup-backup" --check-config >/dev/null
    rm -f "$validation_env"
}

validate_generated_surface

cat <<EOF

Bootstrap surface ready.

Created or preserved:
- env: $ENV_FILE
- paths: $PATHS_FILE
- excludes: $EXCLUDES_FILE
- systemd service: $SYSTEMD_SERVICE_PATH
- systemd timer: $SYSTEMD_TIMER_PATH

Validated automatically:
- systemd unit syntax via systemd-analyze verify
- generated env / config coherence via --check-config

Next steps:
1. Edit $ENV_FILE with your restic repository, credentials, and labels.
2. Edit $PATHS_FILE with the directories you actually want backed up.
3. Run: SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-backup" --check-config
4. Reload units: systemctl --user daemon-reload
5. Enable the timer: systemctl --user enable --now "$(basename "$SYSTEMD_TIMER_PATH")"
EOF
