#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
REPO_ROOT="$(cd "$SCRIPT_DIR/.." && pwd)"
KEEP_TEMP="0"

usage() {
    cat <<EOF
Usage: system3-backup-smoke-test [--keep-temp]

Bootstraps a temporary macOS install surface, seeds synthetic status data, and
verifies that the generated env, launchd plist, dashboard, and SwiftBar output
cohere end to end.
EOF
}

assert_contains() {
    local needle="$1"
    local haystack="$2"

    if command -v rg >/dev/null 2>&1; then
        rg -F -q "$needle" "$haystack"
        return
    fi

    grep -F -q "$needle" "$haystack"
}

assert_not_contains() {
    local needle="$1"
    local haystack="$2"

    if grep -F -q "$needle" "$haystack"; then
        echo "Unexpected content in $haystack: $needle" >&2
        exit 1
    fi
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --keep-temp)
            KEEP_TEMP="1"
            shift
            ;;
        -h|--help)
            usage
            exit 0
            ;;
        *)
            echo "Unknown option: $1" >&2
            usage >&2
            exit 2
            ;;
    esac
done

TMP_ROOT="$(mktemp -d)"
cleanup() {
    if [[ "$KEEP_TEMP" != "1" ]]; then
        rm -rf "$TMP_ROOT"
    fi
}
trap cleanup EXIT

CONFIG_HOME="$TMP_ROOT/config"
STATE_DIR="$TMP_ROOT/state"
LOG_DIR="$TMP_ROOT/log"
DASHBOARD_DIR="$TMP_ROOT/dashboard"
LAUNCH_AGENT_PATH="$TMP_ROOT/LaunchAgents/com.system3.backup.plist"
SWIFTBAR_PLUGIN_PATH="$TMP_ROOT/SwiftBar/backup-chassis.1m.sh"
ENV_FILE="$CONFIG_HOME/system3-backup.env"
SMOKE_DOCS="$TMP_ROOT/smoke-docs"
SMOKE_SNAPSHOT_ID="smoke1234"

mkdir -p "$SMOKE_DOCS"

echo "bootstrap temp install"
SYSTEM3_BACKUP_PLAN_JSON="$TMP_ROOT/install-plan.json"
"$REPO_ROOT/bin/system3-backup" install --platform macos \
    --config-home "$CONFIG_HOME" \
    --state-dir "$STATE_DIR" \
    --log-dir "$LOG_DIR" \
    --dashboard-dir "$DASHBOARD_DIR" \
    --launch-agent-path "$LAUNCH_AGENT_PATH" \
    --swiftbar-plugin-path "$SWIFTBAR_PLUGIN_PATH" \
    --display-name "Backup smoke" \
    --plan \
    --json > "$SYSTEM3_BACKUP_PLAN_JSON"

python3 - "$SYSTEM3_BACKUP_PLAN_JSON" "$ENV_FILE" "$LAUNCH_AGENT_PATH" <<'PY'
import json
import sys

plan_path, env_file, launch_agent_path = sys.argv[1:4]
with open(plan_path) as handle:
    data = json.load(handle)

assert data["mode"] == "plan", data
assert data["platform"] == "macos", data
assert any(item["label"] == "env" and item["path"] == env_file for item in data["outputs"]), data
assert any(item["label"] == "launch_agent" and item["path"] == launch_agent_path for item in data["outputs"]), data
PY

echo "validate macos SwiftBar path migration"
MIGRATION_ROOT="$TMP_ROOT/migration"
MIGRATION_CONFIG_HOME="$MIGRATION_ROOT/config"
MIGRATION_STATE_DIR="$MIGRATION_ROOT/state"
MIGRATION_LOG_DIR="$MIGRATION_ROOT/log"
MIGRATION_DASHBOARD_DIR="$MIGRATION_ROOT/dashboard"
MIGRATION_LAUNCH_AGENT_PATH="$MIGRATION_ROOT/LaunchAgents/com.system3.backup.plist"
MIGRATION_SWIFTBAR_DIR="$MIGRATION_ROOT/SwiftBar"
MIGRATION_SWIFTBAR_PLUGIN_PATH="$MIGRATION_SWIFTBAR_DIR/backup-chassis.1m.sh"
MIGRATION_LEGACY_SWIFTBAR_PATH="$HOME/Library/Application Support/SwiftBar/Plugins/restic-backup.5m.sh"
MIGRATION_ENV_FILE="$MIGRATION_CONFIG_HOME/system3-backup.env"
MIGRATION_PATHS_FILE="$MIGRATION_CONFIG_HOME/paths.txt"
mkdir -p "$MIGRATION_CONFIG_HOME"
cat > "$MIGRATION_PATHS_FILE" <<EOF
$MIGRATION_LEGACY_SWIFTBAR_PATH
EOF

"$REPO_ROOT/bin/system3-backup" install --platform macos \
    --config-home "$MIGRATION_CONFIG_HOME" \
    --state-dir "$MIGRATION_STATE_DIR" \
    --log-dir "$MIGRATION_LOG_DIR" \
    --dashboard-dir "$MIGRATION_DASHBOARD_DIR" \
    --launch-agent-path "$MIGRATION_LAUNCH_AGENT_PATH" \
    --swiftbar-plugin-path "$MIGRATION_SWIFTBAR_PLUGIN_PATH" \
    --display-name "Backup migration smoke" \
    --plan \
    --json > "$MIGRATION_ROOT/install-plan.json"

python3 - "$MIGRATION_ROOT/install-plan.json" "$MIGRATION_PATHS_FILE" <<'PY'
import json
import sys

plan_path, paths_file = sys.argv[1:3]
with open(plan_path) as handle:
    data = json.load(handle)

paths_output = next(item for item in data["outputs"] if item["label"] == "paths")
assert paths_output["path"] == paths_file, data
assert paths_output["action"] == "migrate", data
PY

"$REPO_ROOT/bin/system3-backup" install --platform macos \
    --config-home "$MIGRATION_CONFIG_HOME" \
    --state-dir "$MIGRATION_STATE_DIR" \
    --log-dir "$MIGRATION_LOG_DIR" \
    --dashboard-dir "$MIGRATION_DASHBOARD_DIR" \
    --launch-agent-path "$MIGRATION_LAUNCH_AGENT_PATH" \
    --swiftbar-plugin-path "$MIGRATION_SWIFTBAR_PLUGIN_PATH" \
    --display-name "Backup migration smoke"

assert_contains "$MIGRATION_SWIFTBAR_PLUGIN_PATH" "$MIGRATION_PATHS_FILE"
assert_not_contains "restic-backup.5m.sh" "$MIGRATION_PATHS_FILE"

"$REPO_ROOT/bin/system3-backup" install --platform macos \
    --config-home "$CONFIG_HOME" \
    --state-dir "$STATE_DIR" \
    --log-dir "$LOG_DIR" \
    --dashboard-dir "$DASHBOARD_DIR" \
    --launch-agent-path "$LAUNCH_AGENT_PATH" \
    --swiftbar-plugin-path "$SWIFTBAR_PLUGIN_PATH" \
    --display-name "Backup smoke"

cat > "$CONFIG_HOME/paths.txt" <<EOF
$SMOKE_DOCS
EOF

cat >> "$ENV_FILE" <<EOF

SYSTEM3_BACKUP_SNAPSHOT_MATCH_PATH="$SMOKE_DOCS"
SYSTEM3_BACKUP_BACKUP_PROCESS_MATCH="__smoke_test_no_live_backup__"
SYSTEM3_BACKUP_SCHEDULER_SERVICE=""
SYSTEM3_BACKUP_DISPLAY_NAME="Backup smoke"
SYSTEM3_BACKUP_PID_FILE="$TMP_ROOT/system3-backup.pid"
SYSTEM3_BACKUP_NETWORK_CHECK_URL="https://example.invalid/backup-chassis-smoke"
SYSTEM3_BACKUP_NETWORK_CHECK_HTTP_CODE_OVERRIDE="204"
EOF

python3 - "$STATE_DIR" "$SMOKE_DOCS" "$SMOKE_SNAPSHOT_ID" <<'PY'
import json
import os
import sys
from datetime import datetime, timedelta, timezone

state_dir, smoke_docs, snapshot_id = sys.argv[1:4]
os.makedirs(state_dir, exist_ok=True)

now = datetime.now(timezone.utc).replace(microsecond=0)
snapshot_time = now.isoformat().replace("+00:00", "Z")
check_time = (now - timedelta(minutes=15)).isoformat().replace("+00:00", "Z")
restore_time = (now - timedelta(minutes=10)).isoformat().replace("+00:00", "Z")
next_check_due = (now + timedelta(days=7)).isoformat().replace("+00:00", "Z")
next_restore_due = (now + timedelta(days=30)).isoformat().replace("+00:00", "Z")

status = {
    "state": "complete",
    "phase": "backup",
    "snapshot_id": snapshot_id,
    "completed_at": snapshot_time,
    "updated_at": snapshot_time,
}

verify = {
    "state": "ok",
    "phase": "complete",
    "detail": "Synthetic smoke-test verification state",
    "last_check_ok_at": check_time,
    "last_restore_ok_at": restore_time,
    "next_check_due_at": next_check_due,
    "next_restore_due_at": next_restore_due,
}

snapshots = [{
    "short_id": snapshot_id,
    "time": snapshot_time,
    "paths": [smoke_docs],
    "summary": {
        "total_files_processed": 1,
        "total_bytes_processed": 1024,
        "data_added": 128,
    },
}]

with open(os.path.join(state_dir, "status.json"), "w") as f:
    json.dump(status, f)
with open(os.path.join(state_dir, "verification-status.json"), "w") as f:
    json.dump(verify, f)
with open(os.path.join(state_dir, "snapshots-cache.json"), "w") as f:
    json.dump(snapshots, f)
PY

echo "validate generated plist"
plutil -lint "$LAUNCH_AGENT_PATH" >/dev/null
assert_contains "StartCalendarInterval" "$LAUNCH_AGENT_PATH"
assert_contains "SYSTEM3_BACKUP_LAUNCHED_BY_SCHEDULER" "$LAUNCH_AGENT_PATH"

echo "validate generated plugin shell"
bash -n "$SWIFTBAR_PLUGIN_PATH"

echo "validate generated config"
SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-backup" --check-config > "$TMP_ROOT/check-config.txt"
assert_contains "run_wrapper_script=$REPO_ROOT/bin/system3-backup-wrap-caffeinate" "$TMP_ROOT/check-config.txt"

echo "validate strict missing path status"
MISSING_ROOT="$TMP_ROOT/missing-path"
MISSING_CONFIG_HOME="$MISSING_ROOT/config"
MISSING_STATE_DIR="$MISSING_ROOT/state"
MISSING_LOG_DIR="$MISSING_ROOT/log"
MISSING_DASHBOARD_DIR="$MISSING_ROOT/dashboard"
MISSING_LAUNCH_AGENT_PATH="$MISSING_ROOT/LaunchAgents/com.system3.backup.plist"
MISSING_SWIFTBAR_PLUGIN_PATH="$MISSING_ROOT/SwiftBar/backup-chassis.1m.sh"
MISSING_ENV_FILE="$MISSING_CONFIG_HOME/system3-backup.env"
MISSING_PATHS_FILE="$MISSING_CONFIG_HOME/paths.txt"
MISSING_BACKUP_PATH="$MISSING_ROOT/does-not-exist"

"$REPO_ROOT/bin/system3-backup" install --platform macos \
    --config-home "$MISSING_CONFIG_HOME" \
    --state-dir "$MISSING_STATE_DIR" \
    --log-dir "$MISSING_LOG_DIR" \
    --dashboard-dir "$MISSING_DASHBOARD_DIR" \
    --launch-agent-path "$MISSING_LAUNCH_AGENT_PATH" \
    --swiftbar-plugin-path "$MISSING_SWIFTBAR_PLUGIN_PATH" \
    --display-name "Backup missing-path smoke" >/dev/null
cat > "$MISSING_PATHS_FILE" <<EOF
$MISSING_BACKUP_PATH
EOF
cat >> "$MISSING_ENV_FILE" <<EOF

SYSTEM3_BACKUP_SCHEDULER_SERVICE=""
EOF

if SYSTEM3_BACKUP_ENV_FILE="$MISSING_ENV_FILE" "$REPO_ROOT/bin/system3-backup-backup" > "$MISSING_ROOT/backup.out" 2> "$MISSING_ROOT/backup.err"; then
    echo "Expected backup to fail for missing configured path" >&2
    exit 1
fi
assert_contains "Configured backup path not found: $MISSING_BACKUP_PATH" "$MISSING_ROOT/backup.err"

set +e
SYSTEM3_BACKUP_ENV_FILE="$MISSING_ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$MISSING_ROOT/status.json"
MISSING_STATUS_EXIT="$?"
set -e
if [[ "$MISSING_STATUS_EXIT" -ne 1 ]]; then
    echo "Expected retry-pending status command to exit 1, got $MISSING_STATUS_EXIT" >&2
    exit 1
fi
python3 - "$MISSING_ROOT/status.json" "$MISSING_BACKUP_PATH" <<'PY'
import json
import sys

status_path, missing_path = sys.argv[1:3]
with open(status_path) as handle:
    data = json.load(handle)

assert data["status_code"] == "retry_pending", data
assert data["status_text"] == "Retry pending", data
assert missing_path in data["status_detail"], data
assert data["backup_running"] is False, data
PY

SYSTEM3_BACKUP_ENV_FILE="$MISSING_ENV_FILE" "$REPO_ROOT/bin/system3-backup-swiftbar" > "$MISSING_ROOT/swiftbar.txt"
assert_contains "retry | sfimage=arrow.clockwise" "$MISSING_ROOT/swiftbar.txt"
assert_contains "Configured backup path not found: $MISSING_BACKUP_PATH" "$MISSING_ROOT/swiftbar.txt"

echo "render dashboard"
SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-dashboard" >/dev/null
assert_contains "Backup smoke" "$DASHBOARD_DIR/index.html"
assert_contains "$SMOKE_SNAPSHOT_ID" "$DASHBOARD_DIR/index.html"

echo "render cli status"
SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status > "$TMP_ROOT/status.txt"
assert_contains "Backup smoke: Healthy" "$TMP_ROOT/status.txt"
assert_contains "Snapshot $SMOKE_SNAPSHOT_ID" "$TMP_ROOT/status.txt"
assert_contains "Repository: 1 KB - 1 file" "$TMP_ROOT/status.txt"
assert_contains "Recovery proof: Recoverability verified" "$TMP_ROOT/status.txt"

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$TMP_ROOT/status.json"
python3 - "$TMP_ROOT/status.json" "$SMOKE_SNAPSHOT_ID" <<'PY'
import json
import sys

status_path, snapshot_id = sys.argv[1:3]
with open(status_path) as handle:
    data = json.load(handle)

assert data["display_name"] == "Backup smoke", data
assert data["status_health"] == "ok", data
assert data["status_text"] == "Healthy", data
assert data["verify_health"] == "ok", data
assert data["latest_full_snapshot"] == snapshot_id, data
assert data["latest_full_size_label"] == "1 KB", data
assert data["latest_full_file_count_label"] == "1 file", data
assert data["latest_full_repository_label"] == "Repository: 1 KB - 1 file", data
PY

echo "render menubar"
SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-swiftbar" > "$TMP_ROOT/swiftbar.txt"
assert_contains "externaldrive.badge.checkmark" "$TMP_ROOT/swiftbar.txt"
assert_contains "Last backup:" "$TMP_ROOT/swiftbar.txt"
assert_contains "Repository: 1 KB - 1 file" "$TMP_ROOT/swiftbar.txt"
assert_contains "$SMOKE_SNAPSHOT_ID" "$TMP_ROOT/swiftbar.txt"

echo "render recovered network menubar"
python3 - "$STATE_DIR" <<'PY'
import json
import os
import sys
from datetime import datetime, timedelta, timezone

state_dir = sys.argv[1]
next_attempt = (datetime.now(timezone.utc).replace(microsecond=0) + timedelta(hours=3)).isoformat().replace("+00:00", "Z")
status = {
    "state": "waiting_for_network",
    "phase": "backup",
    "failures": 1,
    "next_attempt": next_attempt,
    "updated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
    "endpoint_http_code": "000",
}

with open(os.path.join(state_dir, "status.json"), "w") as f:
    json.dump(status, f)
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$TMP_ROOT/status-network-recovered.json"
python3 - "$TMP_ROOT/status-network-recovered.json" <<'PY'
import json
import sys

with open(sys.argv[1]) as handle:
    data = json.load(handle)

assert data["raw_current_state"] == "waiting_for_network", data
assert data["current_state"] == "network_available", data
assert data["network_probe_http_code"] == "204", data
assert data["network_reachable"] is True, data
assert data["network_recovered"] is True, data
assert data["status_code"] != "waiting_for_network", data
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-swiftbar" > "$TMP_ROOT/swiftbar-network-recovered.txt"
assert_contains "externaldrive.badge.checkmark" "$TMP_ROOT/swiftbar-network-recovered.txt"
assert_not_contains "net | sfimage=wifi.slash" "$TMP_ROOT/swiftbar-network-recovered.txt"
assert_not_contains "Waiting for network" "$TMP_ROOT/swiftbar-network-recovered.txt"

echo "render running menubar"
printf '%s\n' "$$" > "$TMP_ROOT/system3-backup.pid"
python3 - "$STATE_DIR" <<'PY'
import json
import os
import sys
from datetime import datetime, timedelta, timezone

state_dir = sys.argv[1]
updated_at = (datetime.now(timezone.utc).replace(microsecond=0) - timedelta(minutes=3)).isoformat().replace("+00:00", "Z")
status = {
    "state": "uploading",
    "phase": "backup",
    "pct": 100,
    "bytes_done": 150 * 1024 * 1024,
    "total_bytes_estimate": 128 * 1024 * 1024,
    "files_done": 4426,
    "total_files": 4425,
    "elapsed_s": 61,
    "time": 61,
    "updated_at": updated_at,
}

with open(os.path.join(state_dir, "status.json"), "w") as f:
    json.dump(status, f)
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$TMP_ROOT/status-running.json"
python3 - "$TMP_ROOT/status-running.json" <<'PY'
import json
import sys

with open(sys.argv[1]) as handle:
    data = json.load(handle)

assert data["status_code"] == "backup_running", data
assert data["status_detail"] == "finishing", data
assert data["running_title_label"] == "finishing", data
assert data["running_percent"] is None, data
assert "100%" not in data["running_progress_line"], data
assert data["running_progress_line"] == "Progress: finishing", data
assert data["running_bytes_line"] == "150 MB processed; scan estimate still updating", data
assert data["running_files_line"] == "Files: 4,426 scanned; total estimate updating", data
assert data["running_stale_label"].startswith("Status stale: last progress"), data
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-swiftbar" > "$TMP_ROOT/swiftbar-running.txt"
assert_contains "finishing | sfimage=arrow.triangle.2.circlepath" "$TMP_ROOT/swiftbar-running.txt"
assert_contains "Progress: finishing" "$TMP_ROOT/swiftbar-running.txt"
assert_contains "150 MB processed; scan estimate still updating" "$TMP_ROOT/swiftbar-running.txt"
assert_contains "Files: 4,426 scanned; total estimate updating" "$TMP_ROOT/swiftbar-running.txt"
assert_contains "Status stale: last progress" "$TMP_ROOT/swiftbar-running.txt"
assert_not_contains "0/0GB" "$TMP_ROOT/swiftbar-running.txt"
assert_not_contains "100%" "$TMP_ROOT/swiftbar-running.txt"
assert_not_contains "0 GB remaining" "$TMP_ROOT/swiftbar-running.txt"
assert_not_contains "4,426 of 4,425" "$TMP_ROOT/swiftbar-running.txt"
assert_not_contains "of about 128 MB" "$TMP_ROOT/swiftbar-running.txt"

echo "render running menubar with provisional total"
python3 - "$STATE_DIR" <<'PY'
import json
import os
import sys
from datetime import datetime, timezone

state_dir = sys.argv[1]
status = {
    "state": "uploading",
    "phase": "backup",
    "pct": 34,
    "bytes_done": 2 * 1024**3,
    "total_bytes_estimate": 57 * 1024**3,
    "files_done": 2000,
    "total_files": 10000,
    "elapsed_s": 90,
    "updated_at": datetime.now(timezone.utc).replace(microsecond=0).isoformat().replace("+00:00", "Z"),
}

with open(os.path.join(state_dir, "status.json"), "w") as f:
    json.dump(status, f)
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$TMP_ROOT/status-running-estimate.json"
python3 - "$TMP_ROOT/status-running-estimate.json" <<'PY'
import json
import sys

with open(sys.argv[1]) as handle:
    data = json.load(handle)

assert data["status_code"] == "backup_running", data
assert data["status_detail"] == "2 GB processed", data
assert data["running_title_label"] == "2GB", data
assert "/" not in data["running_title_label"], data
assert data["running_progress_line"] == "Progress: 2 GB processed", data
assert data["running_percent"] is None, data
assert data["running_bytes_line"] == "2 GB processed; scan estimate still updating", data
assert data["running_files_line"] == "Files: 2,000 scanned; total estimate updating", data
assert data["running_total_bytes_estimate"] is None, data
assert data["running_total_files_estimate"] is None, data
serialized = json.dumps(data)
assert "/57GB" not in serialized, data
assert "of about 57 GB" not in serialized, data
assert "Progress: 34%" not in serialized, data
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup-swiftbar" > "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_contains "2GB | sfimage=arrow.triangle.2.circlepath" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_contains "Progress: 2 GB processed" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_contains "2 GB processed; scan estimate still updating" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_contains "Files: 2,000 scanned; total estimate updating" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_not_contains "/57GB" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_not_contains "of about 57 GB" "$TMP_ROOT/swiftbar-running-estimate.txt"
assert_not_contains "Progress: 34%" "$TMP_ROOT/swiftbar-running-estimate.txt"

echo "render running status over stale complete state"
python3 - "$STATE_DIR" "$SMOKE_SNAPSHOT_ID" <<'PY'
import json
import os
import sys
from datetime import datetime, timedelta, timezone

state_dir, snapshot_id = sys.argv[1:3]
completed_at = (datetime.now(timezone.utc).replace(microsecond=0) - timedelta(hours=40)).isoformat().replace("+00:00", "Z")
status = {
    "state": "complete",
    "phase": "backup",
    "snapshot_id": snapshot_id,
    "completed_at": completed_at,
    "updated_at": completed_at,
}

with open(os.path.join(state_dir, "status.json"), "w") as f:
    json.dump(status, f)
PY

SYSTEM3_BACKUP_ENV_FILE="$ENV_FILE" "$REPO_ROOT/bin/system3-backup" status --json > "$TMP_ROOT/status-running-stale-complete.json"
python3 - "$TMP_ROOT/status-running-stale-complete.json" <<'PY'
import json
import sys

with open(sys.argv[1]) as handle:
    data = json.load(handle)

assert data["backup_running"] is True, data
assert data["status_code"] == "backup_running", data
assert data["current_state"] == "uploading", data
assert data["running_title_label"] == "running", data
assert data["running_total_bytes_estimate"] is None, data
PY

echo "check cli help"
"$REPO_ROOT/bin/system3-backup" help > "$TMP_ROOT/help.txt"
assert_contains "install [--platform macos|linux]" "$TMP_ROOT/help.txt"
assert_contains "smoke-test [--platform ...]" "$TMP_ROOT/help.txt"

cat <<EOF
Smoke test passed.

Temp root: $TMP_ROOT
Dashboard output: $DASHBOARD_DIR/index.html
SwiftBar output: $TMP_ROOT/swiftbar.txt
EOF
